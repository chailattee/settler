# Better Auth — generate a secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth web client (same client is used for login AND Gmail read-only).
# In Google Cloud Console → Credentials → OAuth 2.0 Client (Web application):
#   Authorized redirect URI: http://localhost:3000/api/auth/callback/google
# Enable the Gmail API for the project and add the gmail.readonly scope on the
# OAuth consent screen.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OpenAI (matching engine + computer-use filing agent) — used by API routes.
OPENAI_API_KEY=
