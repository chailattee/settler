# Settlers — environment variables. Copy to .env.local and fill in.

# --- LLM (OpenRouter) --------------------------------------------------------
# Required. Extraction + class-action classification run through OpenRouter.
OPENROUTER_API_KEY=sk-or-...
# Optional. Any OpenRouter model slug. Defaults to Haiku 4.5 if unset.
OPENROUTER_MODEL=anthropic/claude-haiku-4.5

# --- Database (Supabase Postgres via Drizzle) --------------------------------
# Optional — the store falls back to in-memory if unset. Needed for persistence
# and for `npm run db:push`. Supabase → Settings → Database → Connection string
# → "Session pooler" (URI).
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# --- Auth (better-auth + Google OAuth) ---------------------------------------
# Required for sign-in and the real Gmail scan. Generate a secret with
# `openssl rand -base64 32`.
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
# Google OAuth client (needs the gmail.readonly scope). Without these, use the
# demo workflow (`{ "demo": true }`).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Class-action lookup (CourtListener) -------------------------------------
# Optional. A token raises rate limits. Either name works.
COURTLISTENER_TOKEN=
# COURTLISTENER_API_TOKEN=

# --- Web search enrichment (Brave + Firecrawl) -------------------------------
# Optional. If BRAVE_API_KEY is unset, web discovery is skipped and only
# CourtListener runs. Firecrawl adds page scraping on top of Brave results.
BRAVE_API_KEY=
FIRECRAWL_API_KEY=